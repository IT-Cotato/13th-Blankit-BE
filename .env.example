# Database
DB_NAME=blankit
DB_USERNAME=blankit_user
# app이 접속에 사용하는 비밀번호 (MySQL root 비밀번호와 동일하게 설정)
DB_PASSWORD=your_password_here
DB_USER_PASSWORD=your_user_password_here
# prod: mysql 컨테이너 서비스명을 호스트로 사용 / local: localhost
DB_URL=jdbc:mysql://localhost:3306/blankit?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia%2FSeoul
